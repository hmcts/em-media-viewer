{
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "commonjs",
    "target": "es2017",
    "sourceMap": false,
    "experimentalDecorators": true,
    "noImplicitAny": false,
    "strict": true,
    "declaration": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": [
      "es2017",
      "dom"
    ],
    "paths": {
      "otp": [
        "../node_modules/otp/dist/otp.d.ts"
      ]
    },
  }
}
